[user]
	name = Robert Francis
	email = robertefrancis18@gmail.com
[core]
	excludesfile = /Users/robertfrancis/.gitignore_global
	pager = LESS=FR delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[diff]
	algorithm = histogram
	colorMoved = default
[pull]
	rebase = true
[init]
	defaultBranch = main
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
